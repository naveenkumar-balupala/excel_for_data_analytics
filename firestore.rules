rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // True only after an admin has released results for the given test.
    function testReleased(testId) {
      return get(/databases/$(database)/documents/tests/$(testId)).data.resultsReleased == true;
    }

    // ---- admins ----
    // A user can read their own admin doc (used for the role check on login).
    // Admin docs are created manually from the Firebase console (see README).
    match /admins/{adminId} {
      allow read: if isSelf(adminId) || isAdmin();
      allow write: if false; // never writable from the client
    }

    // ---- students ----
    // A student creates and reads their own profile; admins can read everyone.
    match /students/{studentId} {
      allow create: if isSelf(studentId);
      allow read, update: if isSelf(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---- usns ----  (USN uniqueness index, doc id = USN)
    // Read-by-id lets a signed-in user check if a USN is taken during
    // registration without listing the private students collection.
    match /usns/{usn} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---- questions ----
    // Any signed-in user may read questions (the client grades the test).
    // NOTE: Firestore rules cannot strip the `correctAnswer` field, so a
    // determined user could inspect it. For exam-grade secrecy, move grading
    // to a Cloud Function and store answers server-side. See README.
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- tests ----
    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- batches ----
    // Anyone signed in (or registering) can read the batch list; admin manages.
    match /batches/{batchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- attempts ----
    // Doc id is `${studentId}_${testId}` (see attemptService.js). Access is
    // gated on the studentId FIELD so that list queries (where studentId == me)
    // are authorized; ID-based rules can't authorize list queries. `resource ==
    // null` allows the "has this been attempted?" get on a not-yet-created doc.
    match /attempts/{attemptId} {
      allow read: if isAdmin()
        || (isSignedIn()
            && (resource == null || resource.data.studentId == request.auth.uid));
      // create only the student's own attempt; the deterministic id + the
      // update/delete block below keep it to a single, immutable attempt.
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- progress ----  (auto-saved in-progress test answers)
    // id = "{studentId}_{testId}". A student manages only their own progress.
    // Stores option order + selected answers, never the answer key.
    match /progress/{progressId} {
      allow read: if isAdmin()
        || (isSignedIn() && progressId.split('_')[0] == request.auth.uid);
      allow create, update, delete: if isSignedIn()
        && progressId.split('_')[0] == request.auth.uid;
    }

    // ---- results ----
    // A student may read their OWN result only after the admin releases results
    // for that test. Admins always can.
    match /results/{resultId} {
      allow read: if isAdmin()
        || (isSignedIn() && (
              resource == null
              || (resource.data.studentId == request.auth.uid
                  && testReleased(resource.data.testId))
           ));
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
